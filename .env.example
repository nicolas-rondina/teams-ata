# Copie este arquivo para .env e preencha com as suas chaves.

# Obrigatória — transcrição e geração da ata (crie em https://console.groq.com/keys)
GROQ_API_KEY=sua_chave_aqui

# Opcional — identificação de participantes por separação de voz (diarização).
# Se preenchida, a transcrição passa a ser feita pela AssemblyAI, que separa os
# locutores. Crie uma chave gratuita em https://www.assemblyai.com/
# Deixe em branco para usar apenas o Groq (sem diarização).
ASSEMBLYAI_API_KEY=
